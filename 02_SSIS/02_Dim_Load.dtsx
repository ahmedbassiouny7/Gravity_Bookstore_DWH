                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    b.book_id,
    b.title,
    b.isbn13,
    b.num_pages,
    b.publication_date,
    YEAR(b.publication_date) AS publication_year,
    bl.language_code,
    bl.language_name,
    p.publisher_name
FROM stg_book b
LEFT JOIN stg_book_language bl ON b.language_id  = bl.language_id
LEFT JOIN stg_publisher p      ON b.publisher_id = p.publisher_id</property>
