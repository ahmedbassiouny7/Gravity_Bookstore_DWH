    <DTS:Executable
      DTS:refId="Package\SQL_Load_Bridge_BookAuthor"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{3630CA05-B597-4F93-B0D8-7D61CC3C4F2E}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Load_Bridge_BookAuthor"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1C56C7A7-89C8-46DB-AA4A-0CEBCB454B6C}"
          SQLTask:SqlStatementSource="INSERT INTO GravityBookstore_DWH.dbo.Bridge_BookAuthor&#xA;(book_SK, author_SK, weighting_factor)&#xA;SELECT&#xA;    db.book_SK,&#xA;    da.author_SK,&#xA;    CAST(1.0 / COUNT(*) OVER (PARTITION BY ba.book_id) AS DECIMAL(5,4))&#xA;FROM GravityBookstore_Staging.dbo.stg_book_author ba&#xA;JOIN GravityBookstore_DWH.dbo.Dim_Book db   ON db.book_NK   = ba.book_id&#xA;JOIN GravityBookstore_DWH.dbo.Dim_Author da ON da.author_NK = ba.author_id&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1 FROM GravityBookstore_DWH.dbo.Bridge_BookAuthor b&#xA;    WHERE b.book_SK   = db.book_SK&#xA;    AND   b.author_SK = da.author_SK&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQL_Load_Bridge_CustomerAddress"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{B2C194D7-A97F-4ED8-8C04-28447025CF1C}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Load_Bridge_CustomerAddress"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1C56C7A7-89C8-46DB-AA4A-0CEBCB454B6C}"
          SQLTask:SqlStatementSource="-- Expire old relationships&#xA;UPDATE b SET&#xA;    b.end_date   = CAST(GETDATE() AS DATE),&#xA;    b.is_current = 0&#xA;FROM GravityBookstore_DWH.dbo.Bridge_CustomerAddress b&#xA;JOIN GravityBookstore_DWH.dbo.Dim_Customer dc ON b.customer_SK = dc.customer_SK&#xA;JOIN GravityBookstore_DWH.dbo.Dim_Address  da ON b.address_SK  = da.address_SK&#xA;WHERE b.is_current = 1&#xA;AND NOT EXISTS (&#xA;    SELECT 1 FROM GravityBookstore_Staging.dbo.stg_customer_address s&#xA;    WHERE s.customer_id = dc.customer_NK&#xA;    AND   s.address_id  = da.address_NK&#xA;);&#xA;&#xA;-- Insert new relationships&#xA;INSERT INTO GravityBookstore_DWH.dbo.Bridge_CustomerAddress&#xA;(customer_SK, address_SK, start_date, end_date, is_current)&#xA;SELECT&#xA;    dc.customer_SK,&#xA;    da.address_SK,&#xA;    CAST(GETDATE() AS DATE),&#xA;    NULL,&#xA;    1&#xA;FROM GravityBookstore_Staging.dbo.stg_customer_address s&#xA;JOIN GravityBookstore_DWH.dbo.Dim_Customer dc&#xA;    ON dc.customer_NK = s.customer_id AND dc.is_current = 1&#xA;JOIN GravityBookstore_DWH.dbo.Dim_Address da&#xA;    ON da.address_NK = s.address_id&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1 FROM GravityBookstore_DWH.dbo.Bridge_CustomerAddress b&#xA;    WHERE b.customer_SK = dc.customer_SK&#xA;    AND   b.address_SK  = da.address_SK&#xA;    AND   b.is_current  = 1&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
