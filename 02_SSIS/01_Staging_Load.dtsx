    DTS:Name="PackageFormatVersion">8</DTS:Property>
  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\SQL_Full_Load_Staging"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{05853341-07F0-4E10-A39F-B6ABB557822D}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Full_Load_Staging"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4BEB09F6-A322-4CD0-AEBE-2FED5EC9BB59}"
          SQLTask:SqlStatementSource="-- INSERT ALL&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_book&#xA;SELECT book_id, title, isbn13, language_id,&#xA;       num_pages, publication_date, publisher_id, GETDATE()&#xA;FROM gravity_books.dbo.book;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_author&#xA;SELECT author_id, author_name, GETDATE()&#xA;FROM gravity_books.dbo.author;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_book_author&#xA;SELECT book_id, author_id, GETDATE()&#xA;FROM gravity_books.dbo.book_author;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_book_language&#xA;SELECT language_id, language_code, language_name, GETDATE()&#xA;FROM gravity_books.dbo.book_language;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_publisher&#xA;SELECT publisher_id, publisher_name, GETDATE()&#xA;FROM gravity_books.dbo.publisher;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_customer&#xA;SELECT customer_id, first_name, last_name, email, GETDATE()&#xA;FROM gravity_books.dbo.customer;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_address&#xA;SELECT address_id, street_number, street_name, city, country_id, GETDATE()&#xA;FROM gravity_books.dbo.address;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_country&#xA;SELECT country_id, country_name, GETDATE()&#xA;FROM gravity_books.dbo.country;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_customer_address&#xA;SELECT customer_id, address_id, status_id, GETDATE()&#xA;FROM gravity_books.dbo.customer_address;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_address_status&#xA;SELECT status_id, address_status, GETDATE()&#xA;FROM gravity_books.dbo.address_status;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_shipping_method&#xA;SELECT method_id, method_name, cost, GETDATE()&#xA;FROM gravity_books.dbo.shipping_method;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_order_status&#xA;SELECT status_id, status_value, GETDATE()&#xA;FROM gravity_books.dbo.order_status;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_cust_order&#xA;SELECT order_id, order_date, customer_id,&#xA;       shipping_method_id, dest_address_id, GETDATE()&#xA;FROM gravity_books.dbo.cust_order;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_order_line&#xA;SELECT line_id, order_id, book_id, price, GETDATE()&#xA;FROM gravity_books.dbo.order_line;&#xA;&#xA;INSERT INTO GravityBookstore_Staging.dbo.stg_order_history&#xA;SELECT history_id, order_id, status_id, status_date, GETDATE()&#xA;FROM gravity_books.dbo.order_history;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQL_Log_Success"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{839E28A5-24BA-469A-B4E5-084F61F64847}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Log_Success"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4BEB09F6-A322-4CD0-AEBE-2FED5EC9BB59}"
          SQLTask:SqlStatementSource="INSERT INTO GravityBookstore_Staging.dbo.etl_error_log&#xA;    (package_name, error_message, error_time)&#xA;VALUES&#xA;    ('01_Staging_Load', 'Staging load completed successfully', GETDATE());" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQL_Verify_Staging"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{177F8E60-D1DC-4456-AF4A-8D1E86A4EC79}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Verify_Staging"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4BEB09F6-A322-4CD0-AEBE-2FED5EC9BB59}"
          SQLTask:SqlStatementSource="IF EXISTS (&#xA;    SELECT 1 WHERE&#xA;    (SELECT COUNT(*) FROM gravity_books.dbo.book) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_book)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.author) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_author)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.book_author) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_book_author)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.book_language) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_book_language)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.publisher) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_publisher)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.customer) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_customer)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.address) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_address)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.country) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_country)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.customer_address) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_customer_address)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.address_status) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_address_status)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.shipping_method) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_shipping_method)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.order_status) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_order_status)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.cust_order) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_cust_order)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.order_line) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_order_line)&#xA;&#xA;    OR (SELECT COUNT(*) FROM gravity_books.dbo.order_history) != &#xA;    (SELECT COUNT(*) FROM GravityBookstore_Staging.dbo.stg_order_history)&#xA;)&#xA;BEGIN&#xA;    RAISERROR('Staging row count mismatch detected!', 16, 1);&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Truncate Staging Tables"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{2E346D68-CD29-42CF-A960-962BB31E7ED3}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Truncate Staging Tables"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4BEB09F6-A322-4CD0-AEBE-2FED5EC9BB59}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE stg_book;&#xA;TRUNCATE TABLE stg_author;&#xA;TRUNCATE TABLE stg_book_author;&#xA;TRUNCATE TABLE stg_book_language;&#xA;TRUNCATE TABLE stg_publisher;&#xA;TRUNCATE TABLE stg_customer;&#xA;TRUNCATE TABLE stg_address;&#xA;TRUNCATE TABLE stg_country;&#xA;TRUNCATE TABLE stg_customer_address;&#xA;TRUNCATE TABLE stg_address_status;&#xA;TRUNCATE TABLE stg_shipping_method;&#xA;TRUNCATE TABLE stg_order_status;&#xA;TRUNCATE TABLE stg_cust_order;&#xA;TRUNCATE TABLE stg_order_line;&#xA;TRUNCATE TABLE stg_order_history;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
