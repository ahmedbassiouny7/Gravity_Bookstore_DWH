  <Source dwd:design-time-name="06a8f7a9-5ef3-4886-a173-61504e2d7937">
    <DataSourceViewID>Gravity Bookstore DWH</DataSourceViewID>
  </Source>
  <MdxScripts>
    <MdxScript dwd:design-time-name="a92457b8-fa45-4b8a-9a2c-70d7b0d5a72a">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].[Total Revenue]
 AS [Measures].[Sale Price], 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Total Orders]
 AS [Measures].[Fact Book Sales Count], 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Total Shipping Cost]
 AS [Measures].[Shipping Cost], 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Order Value]
 AS IIF(
    [Measures].[Total Orders] = 0,
    NULL,
    [Measures].[Total Revenue] / [Measures].[Total Orders]
), 
FORMAT_STRING = "Currency", 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Revenue Growth %]
 AS IIF(
    PARALLELPERIOD([Dim Date].[Year].[Year], -1, [Dim Date].[Year].CurrentMember) = 0,
    NULL,
    ([Measures].[Total Revenue] - ([Measures].[Total Revenue], PARALLELPERIOD([Dim Date].[Year].[Year], -1, [Dim Date].[Year].CurrentMember)))
    / ([Measures].[Total Revenue], PARALLELPERIOD([Dim Date].[Year].[Year], -1, [Dim Date].[Year].CurrentMember))
), 
FORMAT_STRING = "Currency", 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>